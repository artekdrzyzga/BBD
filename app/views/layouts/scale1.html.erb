<!DOCTYPE HTML>
<!--
-->
<html>
	<head>
		<title>By British Design</title>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>


    <%= stylesheet_link_tag    'scale', media: 'all', 'data-turbolinks-track': 'reload' %>
    <%= javascript_include_tag 'scale', 'data-turbolinks-track': 'reload' %>

	</head>
	<body class="is-preload">
		<!-- Wrapper -->
			<div id="wrapper">
				<!-- Main -->
					<div id="main">
						<div class="inner"> 
							<!-- Header -->
								<header id="header">
									
									
									 <%= link_to cart_path, :class => "koszyk", style: 'color:#6c757d'  do %>
                                        <span class="fa fa-shopping-cart"></span>
                                        <%= current_cart.line_items.map { |e| e.quantity }.sum %>
                                        products for
                                       <%= number_to_currency(current_cart.line_items.map { |e| e.full_price }.sum) %>
                                     <% end %>
                                      
                                     <% if current_user %>
                                       <span><%= current_user.email %></span>
                                        <%= link_to  sign_out_path, method: :delete  do %>Log Out
                                           <span class="fa fa-sign-out-alt"></span>
                                        <% end %>
                                     <% else %>
                                       <%= link_to  sign_in_path  do %>Log In
                                           <span class="fa fa-sign-in-alt"></span>
                                       <% end %>
                                     <% end %>

									<ul class="icons">
										<li><a href="#" class="icon brands fa-twitter"><span class="label">Twitter</span></a></li>
										<li><a href="https://www.facebook.com/By-British-Design-111278024036098" class="icon brands fa-facebook-f"><span class="label">Facebook</span></a></li>
										<li><a href="#" class="icon brands fa-snapchat-ghost"><span class="label">Snapchat</span></a></li>
										<li><a href="#" class="icon brands fa-instagram"><span class="label">Instagram</span></a></li>
										<li><a href="#" class="icon brands fa-medium-m"><span class="label">Medium</span></a></li>
									</ul>
								</header>

							<!-- Banner -->
                               <% if controller.controller_name != "cart" && controller.controller_name != "user_sessions" && controller.controller_name != "users" && controller.controller_name != "password_resets"   %>
                              
							   
							   
							       <section id="banner">
									<div class="content">
										<header>
											<h1>By British Design</h1>
											<p>A aaaaaaaaa</p>
										</header>
										<p>BY BRITISH DESIGN- pop up Christmas store, opening on Saturday the 17th of October. We offer beautiful exquisite  decorations from Gisela Graham, Enchante, Sage, Festive and many other high end brands. Our very own hand crafted, one off designed unique wreaths and baubles will be showcased and sold! 
                                           Join us at 28a-b Queens Parade, Friern Barnet Road, Friern Barnet, London, N11 3DA. 
                                           Monday to Saturday from 9.30am to 7.00pm. 
                                           Sunday 10.00am to 5.00pm</p>
										<ul class="actions">
											<li><a href="#" class="button big">Learn More</a></li>
										</ul>
									</div>
									<span class="image object">	
                                         <%= image_tag("front.jpg") %> 
									</span>
								</section>
							   
							   
							   
							   
							   
							   <%else%>
                               

							  
							  
							   <%end%>






								

							<!-- Section -->
							<!-- Section -->
							   <div class="container">
                                       <%= yield %>
                                </div>


						</div>
					</div>

				<!-- Sidebar -->
					<div id="sidebar">
						<div class="inner">
							<!-- Search -->
								<section id="search" class="alt">
									<form method="post" action="#">
										<input type="text" name="query" id="query" placeholder="Search" />
									</form>
								</section>

							<!-- Menu -->
								<nav id="menu">
									<header class="major">
										<h2>Categories</h2>
									</header>

                                     <ul>
                                       <% Category.all.each do |category| %>
                                         <li>
                                           <%= link_to category.name, category_path(category)%>
                                         </li>
                                       <% end %>
                                     </ul>
								</nav>


							<!-- Section -->
							<!-- Section -->
								<section>
									<header class="major">
										<h2>Get in touch</h2>
									</header>
									<p>Sed varius enim lorem ullamcorper dolore aliquam aenean ornare velit lacus, ac varius enim lorem ullamcorper dolore. Proin sed aliquam facilisis ante interdum. Sed nulla amet lorem feugiat tempus aliquam.</p>
									<ul class="contact">
										<li class="icon solid fa-envelope"><a href="#">info@bybritishdesign.com</a></li>
										<li class="icon solid fa-phone">07854 111776</li>
										<li class="icon solid fa-home">28a-b Queens Parade, Friern Barnet Road, Friern Barnet,
                                          London, N11 3DA<br />
										  Nashville, TN 00000-0000</li>
									</ul>
								</section>

							<!-- Footer -->
								<footer id="footer">
									<p class="copyright">&copy; Untitled. All rights reserved. Demo Images: <a href="https://unsplash.com">Unsplash</a>. Design: <a href="https://html5up.net">HTML5 UP</a>.</p>
								</footer>

						</div>
					</div>

			</div>

		<!-- Scripts -->
	</body>
</html>





<!DOCTYPE html>
<html>
  <head>
    <title>PanikoShop1</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag    'application', media: 'all', 'data-turbolinks-track': 'reload' %>
    <%= javascript_include_tag 'application', 'data-turbolinks-track': 'reload' %>
  </head>

  <body style="background-color: #F6F0E4;">


  <div class="container-fluid p-1">
    <div class="row justify-content-sm-center;" style="height: 120px;"">
      <div class="col col-sm-2">
        <%= image_tag("BBD_LOGO.png", size: "120x140") %>
      </div>
      <div class="col col-sm-8 border ">
        <p class="text-center">By British Design Limited</p>
        <p class="text-center" style="font-size: 16px">EST 2020 </p>
      </div>
      <div class="col col-sm-2">
      
       <li>
           <%= link_to cart_path, :class => "koszyk" do %>
            <span class="fa fa-shopping-cart"></span>
            <%= current_cart.line_items.map { |e| e.quantity }.sum %>
            products for
            <%= number_to_currency(current_cart.line_items.map { |e| e.full_price }.sum) %>
          <% end %>
        </li>
      </ul>

      </div>
    </div>  
  </div>
  
  
    
<nav class="navbar navbar-expand-sm shadow p-3 mb-5 rounded sticky-top" style="background-color: #E8DFCE;">
    <div class="container >
      <div class="navbar-header">
        <a class="navbar-brand" style="font-size: 30px" href="<%= root_path %>"><span class="fa fa-home" style="color: #5F5A51" ></span></a>
        <a class="navbar-brand text-secondary" href="#">Privacy policy</a>
        <a class="navbar-brand text-secondary" href="#">Regulations</a>
        <a class="navbar-brand text-secondary" href="#">Delivery and payments</a>
         <a class="navbar-brand text-secondary" href="#">About the store</a>
      </div>
     
     
  



    </div>

      
    
</nav>


     <div class="container-fluid">
    <div class="row">
      <div class="col-md-2 border">
        <h3 class="text-center" >Categories</h3>
        <ul>
          <% Category.all.each do |category| %>
          <li>
            <%= link_to category.name, category_path(category), style: 'color:#5f5A51; font-size: 20px;' %>
          </li>
          <% end %>
        </ul>
      </div>
      <div class="col-md-10">
      
        <%= yield %>
      </div>
    </div>
  </div>





 
  </body>
</html>

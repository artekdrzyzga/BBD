<%= simple_form_for [:admin, @product] do |f| %>
  <%= f.input :name %>
  <%= f.input :description %>
  <%= f.input :code %>
  <%= f.input :price %>
  <%#= f.input :width %>
  <%#= f.input :height %>
  <%= f.input :quantity %>
  <%= f.input :status, :label => "Visible" %>
  
  <%= f.association :category %>
  <%= f.input :picture, as: :file %>


 
  <%#= f.association :category %>
  <%= f.submit class: "btn btn-success" %>
<% end %>



  <%= link_to new_admin_product_path, class: "btn btn-success" do %>
  <span class="fa fa-plus fa-spin"></span> Add new product
<% end %>

 <table class="table table-striped">
    <thead>
    <tr>
      <th>Product code</th>
      <th>Name</th>
      <th>Price</th>
      <th>Category</th> 
      <th>Edit</th>
      <th>Delete</th>
    </tr>
   </thead>

    <tbody>
      <% @products.each do |product| %>
        <tr>
          <td><%= product.code %></td>
          <td><%= product.name %></td>
          <td><%= number_to_currency product.price %></td> 
          <td><%= product.category.name %></td>
          <td>
            <%= link_to edit_admin_product_path(product), class: "btn btn-default btn-xs" do %>
              <span class="fa fa-edit"></span>
            <%end%>
          </td>
          <td>
            <%= link_to admin_product_path(product), method: :delete, class: "btn btn-default btn-xs",data: {confirm: "Are you sure ?"} do %>
              <span class="fa fa-trash"></span>
            <%end%>
          </td>


        </tr>
      <% end %>
     </tbody> 
     
   </table>   
<%= paginate @products %>